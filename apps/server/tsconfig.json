{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "src",              /* આ લાઈન ઉમેરો: આનાથી dist માં src ફોલ્ડર નહીં બને, સીધી ફાઈલો આવશે */
    "baseUrl": ".",                /* પ્રોજેક્ટનો રૂટ પાથ સેટ કરવા માટે */
    "types": ["node"]
  },
  "include": ["src/**/*", "../../shared/**/*"]
}