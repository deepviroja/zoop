{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": false,     /* આ લાઈન ઉમેરો - any ટાઇપની એરર બંધ થશે */
    "skipLibCheck": true,
    "outDir": "./dist",
    "types": ["node"]           /* આ લાઈન ઉમેરો - process એરર માટે */
  },
  "include": ["src/**/*", "../../shared/**/*"]
}